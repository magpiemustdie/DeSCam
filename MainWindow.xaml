<Window x:Class="DeSCam.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DeSCam"
        Title="DeSCam"
        Icon="pack://application:,,,/demons_souls-square.ico"
        Width="1100" Height="740" MinWidth="900" MinHeight="580"
        Background="#1e1e1e" FontFamily="Consolas" FontSize="12">

    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="BG"     Color="#1e1e1e"/>
        <SolidColorBrush x:Key="BG2"    Color="#252526"/>
        <SolidColorBrush x:Key="BG3"    Color="#2d2d30"/>
        <SolidColorBrush x:Key="FG"     Color="#d4d4d4"/>
        <SolidColorBrush x:Key="Gold"   Color="#c8a84b"/>
        <SolidColorBrush x:Key="Green"  Color="#4ec94e"/>
        <SolidColorBrush x:Key="Gray"   Color="#6a9955"/>
        <SolidColorBrush x:Key="Accent" Color="#0e639c"/>
        <SolidColorBrush x:Key="Entry"  Color="#3c3c3c"/>
        <SolidColorBrush x:Key="Red"    Color="#f44747"/>

        <!-- Button base style -->
        <Style x:Key="DarkBtn" TargetType="Button">
            <Setter Property="Background"  Value="#3c3c3c"/>
            <Setter Property="Foreground"  Value="#d4d4d4"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"     Value="8,3"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="FontFamily"  Value="Consolas"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0e639c"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0a4d7a"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Gold button -->
        <Style x:Key="GoldBtn" TargetType="Button" BasedOn="{StaticResource DarkBtn}">
            <Setter Property="Background"  Value="#c8a84b"/>
            <Setter Property="Foreground"  Value="#1e1e1e"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e0c060"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Red button -->
        <Style x:Key="RedBtn" TargetType="Button" BasedOn="{StaticResource DarkBtn}">
            <Setter Property="Background" Value="#8b1a1a"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#c0392b"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Tab style -->
        <Style TargetType="TabItem">
            <Setter Property="Background"  Value="#2d2d30"/>
            <Setter Property="Foreground"  Value="#d4d4d4"/>
            <Setter Property="Padding"     Value="12,5"/>
            <Setter Property="FontFamily"  Value="Consolas"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" Margin="0,0,2,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#252526"/>
                                <Setter Property="Foreground" Value="#c8a84b"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3c3c3c"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox style -->
        <Style TargetType="TextBox">
            <Setter Property="Background"    Value="#3c3c3c"/>
            <Setter Property="Foreground"    Value="#d4b483"/>
            <Setter Property="CaretBrush"    Value="#c8a84b"/>
            <Setter Property="BorderBrush"   Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"       Value="3,1"/>
            <Setter Property="FontFamily"    Value="Consolas"/>
            <Setter Property="FontSize"      Value="11"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- CheckBox style -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground"  Value="#d4d4d4"/>
            <Setter Property="FontFamily"  Value="Consolas"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- DataGrid style -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"              Value="#1e1e1e"/>
            <Setter Property="Foreground"              Value="#d4d4d4"/>
            <Setter Property="RowBackground"           Value="#1e1e1e"/>
            <Setter Property="AlternatingRowBackground" Value="#2d2d30"/>
            <Setter Property="GridLinesVisibility"     Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#333"/>
            <Setter Property="BorderThickness"         Value="0"/>
            <Setter Property="ColumnHeaderHeight"      Value="26"/>
            <Setter Property="RowHeight"               Value="24"/>
            <Setter Property="FontFamily"              Value="Consolas"/>
            <Setter Property="FontSize"                Value="11"/>
            <Setter Property="SelectionMode"           Value="Single"/>
            <Setter Property="SelectionUnit"           Value="FullRow"/>
            <Setter Property="AutoGenerateColumns"     Value="False"/>
            <Setter Property="CanUserAddRows"          Value="False"/>
            <Setter Property="CanUserDeleteRows"       Value="False"/>
            <Setter Property="CanUserReorderColumns"   Value="False"/>
            <Setter Property="IsReadOnly"              Value="True"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"  Value="#252526"/>
            <Setter Property="Foreground"  Value="#c8a84b"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Padding"     Value="6,0"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0e639c"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Top status bar -->
        <Border DockPanel.Dock="Top" Background="#252526" Height="32">
            <DockPanel Margin="8,0">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Button Content="Connect" Style="{StaticResource GoldBtn}"
                            Click="Connect_Click" Margin="0,0,4,0" Padding="8,2"/>
                    <Button Content="Disconnect" Style="{StaticResource DarkBtn}"
                            Click="Disconnect_Click" Margin="0,0,12,0" Padding="8,2"/>
                </StackPanel>
                <TextBlock Text="{Binding ConnStatus}" Foreground="#c8a84b"
                           FontWeight="Bold" FontSize="12"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <TabControl Background="#1e1e1e" BorderThickness="0" Margin="6" SelectedIndex="1">

            <!-- ══ Tab 1: Connection ══════════════════════════════════════════ -->
            <TabItem Header=" Connection ">
                <Grid Background="#1e1e1e" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Buttons -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,8,0,8">
                        <Button Content="Verify Strings" Style="{StaticResource DarkBtn}"
                                Click="Verify_Click" Margin="0,0,6,0"/>
                        <Button Content="🔍 Diagnostics" Style="{StaticResource DarkBtn}"
                                Click="Diag_Click"/>
                    </StackPanel>

                    <!-- Status strip -->
                    <Border Grid.Row="1" Background="#2d2d30" Padding="10,5" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Status: " Foreground="#6a9955" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding StatusText}" Foreground="#d4d4d4" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Grid.Row="1" Text="String Verification"
                               Foreground="#c8a84b" FontWeight="Bold" FontSize="13"
                               Margin="0,44,0,0"/>

                    <!-- Strings treeview -->
                    <DataGrid Grid.Row="2" x:Name="StringsGrid" MaxHeight="200">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name"     Width="160" Binding="{Binding Name}"/>
                            <DataGridTextColumn Header="PS3 Addr" Width="130" Binding="{Binding Addr}"/>
                            <DataGridTextColumn Header="Value"    Width="*"   Binding="{Binding Value}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ══ Tab 2: ChrFollowCam ════════════════════════════════════════ -->
            <TabItem Header=" ChrFollowCam ">
                <Grid Background="#1e1e1e">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,8,8,4">
                        <Button Content="↺ Refresh" Style="{StaticResource DarkBtn}"
                                Click="Refresh_Click" Margin="0,0,3,0"/>
                        <Button Content="⚡ Find ChrFollowCam" Style="{StaticResource GoldBtn}"
                                Click="Find_Click" Margin="0,0,3,0"/>
                        <CheckBox Content="● Auto" IsChecked="{Binding AutoRefresh}"
                                  Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <CheckBox Content="RangeCheck" IsChecked="{Binding FovRangeCheckEnabled}"
                                  Margin="0,0,6,0" VerticalAlignment="Center"
                                  ToolTip="~5.7°..183° FovY range check (disable to accept any value during transitions)"/>
                        <CheckBox x:Name="DebugEbootCheck" Content="Debug EBOOT"
                                  IsChecked="{Binding DebugEboot}" Foreground="#c8a84b"
                                  Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <Button Content="↺ Reset All" Style="{StaticResource DarkBtn}"
                                Click="ResetAll_Click" Margin="0,0,3,0"/>
                        <Button Content="⊘ Reset UI" Style="{StaticResource DarkBtn}"
                                Click="ResetUI_Click" Margin="0,0,3,0"
                                ToolTip="Clear table and reset to initial state"/>
                        <Button Content="📂 Preset" Style="{StaticResource DarkBtn}"
                                Click="LoadPreset_Click" Margin="0,0,3,0"
                                ToolTip="Load Name=Value pairs from file, set and lock params"/>

                        <TextBlock Text="lock:" Foreground="#6a9955" FontFamily="Consolas" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,3,0"/>
                        <TextBox x:Name="LockIntervalBox"
                                 Text="{Binding LockIntervalMs, UpdateSourceTrigger=LostFocus}"
                                 Width="44" FontFamily="Consolas" FontSize="11"
                                 VerticalContentAlignment="Center" Margin="0,0,3,0"
                                 ToolTip="Lock write interval in milliseconds (default: 250)"/>
                        <Button Content="✓" Style="{StaticResource DarkBtn}" Width="24"
                                Click="LockInterval_Click" Margin="0,0,8,0"
                                ToolTip="Apply lock interval"/>
                        <TextBlock Text="refresh:" Foreground="#6a9955" FontFamily="Consolas" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,3,0"/>
                        <TextBox x:Name="RefreshIntervalBox"
                                 Text="{Binding RefreshIntervalMs, UpdateSourceTrigger=LostFocus}"
                                 Width="44" FontFamily="Consolas" FontSize="11"
                                 VerticalContentAlignment="Center" Margin="0,0,3,0"
                                 ToolTip="Auto-refresh interval in milliseconds (default: 500)"/>
                        <Button Content="✓" Style="{StaticResource DarkBtn}" Width="24"
                                Click="RefreshInterval_Click"
                                ToolTip="Apply refresh interval"/>
                    </StackPanel>

                    <!-- Node label -->
                    <TextBlock Grid.Row="1" Text="{Binding NodeText}"
                               Foreground="#c8a84b" FontStyle="Italic"
                               Margin="12,0,12,6"/>

                    <!-- Param grid -->
                    <DataGrid Grid.Row="2" x:Name="ParamGrid" Margin="6,0,6,6"
                              ItemsSource="{Binding Params}"
                              SelectionUnit="Cell"
                              EnableRowVirtualization="True">
                        <DataGrid.Columns>
                            <!-- Name -->
                            <DataGridTextColumn Header="Parameter" Width="220"
                                                Binding="{Binding Name}" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="6,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Live value -->
                            <DataGridTextColumn Header="Live" Width="100"
                                                Binding="{Binding Live}" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground"        Value="#4ec94e"/>
                                        <Setter Property="FontWeight"        Value="Bold"/>
                                        <Setter Property="TextAlignment"     Value="Right"/>
                                        <Setter Property="Padding"           Value="6,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- PS3 Address -->
                            <DataGridTextColumn Header="PS3 Addr" Width="100"
                                                Binding="{Binding AddrHex}" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground"        Value="#c8a84b"/>
                                        <Setter Property="Padding"           Value="6,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- CE Address -->
                            <DataGridTextColumn Header="CE Addr" Width="110"
                                                Binding="{Binding AddrCE}" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground"        Value="#ce9178"/>
                                        <Setter Property="Padding"           Value="6,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="ToolTip"           Value="Address in Cheat Engine (attach to rpcs3.exe)"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Input — всегда редактируемое поле -->
                            <DataGridTemplateColumn Header="Set Value" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Input, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="#3c3c3c" Foreground="#d4b483"
                                                 BorderBrush="#555" BorderThickness="1"
                                                 CaretBrush="#c8a84b"
                                                 Padding="3,1" FontFamily="Consolas" FontSize="11"
                                                 VerticalContentAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Unit -->
                            <DataGridTextColumn Header="" Width="30"
                                                Binding="{Binding Unit}" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground"        Value="#6a9955"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Write button + Lock button + Save button -->
                            <DataGridTemplateColumn Header="" Width="145">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Write"
                                                    Style="{StaticResource DarkBtn}"
                                                    FontSize="10" Padding="5,2"
                                                    Width="52" Margin="0,0,2,0"
                                                    Tag="{Binding}"
                                                    Click="WriteParam_Click"/>
                                            <Button Content="{Binding LockLabel}"
                                                    FontSize="11" Padding="3,2"
                                                    Width="28" Margin="0,0,2,0"
                                                    Tag="{Binding}"
                                                    Click="LockParam_Click">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource DarkBtn}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                <Setter Property="Background" Value="#8b1a1a"/>
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Content="💾"
                                                    Style="{StaticResource DarkBtn}"
                                                    FontSize="11" Padding="3,2"
                                                    Width="28"
                                                    Tag="{Binding}"
                                                    Click="SaveParam_Click"
                                                    ToolTip="Save value to preset.txt"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Description -->
                            <DataGridTextColumn Header="Description" Width="*"
                                                Binding="{Binding Description}" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground"        Value="#6a9955"/>
                                        <Setter Property="Padding"           Value="6,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ══ Tab 3: FovY Scan ══════════════════════════════════════════ -->
            <TabItem Header=" FovY Scan ">
                <Grid Background="#1e1e1e">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Vertical">
                      <!-- Row 1: scan + write -->
                      <StackPanel Orientation="Horizontal" Margin="8,8,8,2">
                        <Button Content="🔍 Scan FovY" Style="{StaticResource GoldBtn}"
                                Click="FovyScan_Click" Margin="0,0,6,0"/>
                        <TextBlock Text="min°" Foreground="#6a9955" FontFamily="Consolas" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,3,0"/>
                        <TextBox x:Name="FovyScanMin" Text="42.9" Width="48"
                                 FontFamily="Consolas" FontSize="11"
                                 VerticalContentAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="max°" Foreground="#6a9955" FontFamily="Consolas" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,3,0"/>
                        <TextBox x:Name="FovyScanMax" Text="43.1" Width="48"
                                 FontFamily="Consolas" FontSize="11"
                                 VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Write" Foreground="#d4d4d4" FontFamily="Consolas" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox x:Name="FovyWriteValue" Text="120" Width="50"
                                 FontFamily="Consolas" FontSize="11"
                                 VerticalContentAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="° rows" Foreground="#d4d4d4" FontFamily="Consolas" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox x:Name="FovyFromRow" Text="700" Width="50"
                                 FontFamily="Consolas" FontSize="11"
                                 VerticalContentAlignment="Center" Margin="0,0,2,0"/>
                        <TextBlock Text=".." Foreground="#6a9955" FontFamily="Consolas" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,2,0"/>
                        <TextBox x:Name="FovyToRow" Text="800" Width="50"
                                 FontFamily="Consolas" FontSize="11"
                                 VerticalContentAlignment="Center" Margin="0,0,6,0"/>
                        <Button Content="Write" Style="{StaticResource DarkBtn}"
                                Click="FovyWriteAll_Click" Margin="0,0,12,0"/>
                        <TextBlock Text="Go to:" Foreground="#555" FontFamily="Consolas" FontSize="10"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox x:Name="FovyGotoIndex" Text="0" Width="60"
                                 FontFamily="Consolas" FontSize="11"
                                 VerticalContentAlignment="Center" Margin="0,0,4,0"/>
                        <Button Content="Go" Style="{StaticResource DarkBtn}"
                                Click="FovyGoto_Click" Margin="0,0,12,0"/>
                        <TextBlock Text="count:" Foreground="#555" FontFamily="Consolas" FontSize="10"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock x:Name="FovyScanCount" Text="0"
                                   Foreground="#c8a84b" FontFamily="Consolas" FontSize="10"
                                   VerticalAlignment="Center"/>
                      </StackPanel>
                      <!-- Row 2: binary search -->
                      <StackPanel Orientation="Horizontal" Margin="8,2,8,4">
                        <TextBlock Text="🔀 BinSearch:" Foreground="#c8a84b" FontFamily="Consolas" FontSize="10"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Button Content="▶ Start" Style="{StaticResource DarkBtn}"
                                Click="BsStart_Click" Margin="0,0,4,0"
                                ToolTip="Init binary search from From..To range"/>
                        <Button Content="✓ Fix Left" Margin="0,0,2,0"
                                Click="BsFixLeft_Click"
                                ToolTip="Left half had effect → narrow to left">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource DarkBtn}">
                                    <Setter Property="Background" Value="#1a5c1a"/>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="◀ Left" Style="{StaticResource DarkBtn}"
                                Click="BsLeft_Click" Margin="0,0,8,0"
                                ToolTip="Write FoV to LEFT half"/>
                        <Button Content="▶ Right" Style="{StaticResource DarkBtn}"
                                Click="BsRight_Click" Margin="0,0,2,0"
                                ToolTip="Write FoV to RIGHT half"/>
                        <Button Content="✓ Fix Right" Margin="0,0,8,0"
                                Click="BsFixRight_Click"
                                ToolTip="Right half had effect → narrow to right">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource DarkBtn}">
                                    <Setter Property="Background" Value="#1a5c1a"/>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="↺ Reset" Style="{StaticResource DarkBtn}"
                                Click="BsReset_Click" Margin="0,0,8,0"/>
                        <TextBlock x:Name="BsStatus" Text="{Binding BsStatusText}"
                                   Foreground="#6a9955" FontFamily="Consolas" FontSize="10"
                                   VerticalAlignment="Center"/>
                      </StackPanel>
                    </StackPanel>

                    <TextBlock Grid.Row="1" x:Name="FovyScanStatus"
                               Text="Press Scan to find all FovY addresses"
                               Foreground="#c8a84b" FontFamily="Consolas" FontSize="10"
                               Margin="12,0,12,4"/>

                    <DataGrid Grid.Row="2" x:Name="FovyScanGrid" Margin="6,0,6,6"
                              AutoGenerateColumns="False" IsReadOnly="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              EnableRowVirtualization="True"
                              Background="#1e1e1e" Foreground="#d4d4d4"
                              RowBackground="#1e1e1e" AlternatingRowBackground="#2d2d30"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#333"
                              BorderThickness="0" FontFamily="Consolas" FontSize="11">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PS3 Address" Width="120"
                                                Binding="{Binding AddrHex}" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#c8a84b"/>
                                        <Setter Property="Padding" Value="6,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="CE Address (rpcs3)" Width="140"
                                                Binding="{Binding AddrCE}" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#ce9178"/>
                                        <Setter Property="Padding" Value="6,0"/>
                                        <Setter Property="ToolTip" Value="Use this address in Cheat Engine attached to rpcs3.exe"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Current (°)" Width="100"
                                                Binding="{Binding LiveDeg}" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#4ec94e"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Padding" Value="6,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Set Value (°)" Width="120"
                                                Binding="{Binding SetValue, UpdateSourceTrigger=PropertyChanged}"
                                                IsReadOnly="False">
                                <DataGridTextColumn.EditingElementStyle>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Background" Value="#3c3c3c"/>
                                        <Setter Property="Foreground" Value="#d4b483"/>
                                        <Setter Property="BorderBrush" Value="#555"/>
                                    </Style>
                                </DataGridTextColumn.EditingElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Write" Style="{StaticResource DarkBtn}"
                                                FontSize="10" Padding="5,2"
                                                Tag="{Binding}"
                                                Click="FovyWrite_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding LockLabel}"
                                                FontSize="11" Padding="3,2"
                                                Tag="{Binding}"
                                                Click="FovyLock_Click">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource DarkBtn}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                            <Setter Property="Background" Value="#8b1a1a"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Context" Width="*"
                                                Binding="{Binding Context}" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#6a9955"/>
                                        <Setter Property="Padding" Value="6,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ══ Tab 4: Log ═════════════════════════════════════════════════ -->
            <TabItem Header=" Log ">
                <Grid Background="#1e1e1e">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                     <ListBox Grid.Row="0" x:Name="LogList"
                              Background="#2d2d30" Foreground="#d4d4d4"
                              FontFamily="Consolas" FontSize="10"
                              BorderThickness="0" Margin="6,6,6,0"
                              ItemsSource="{Binding Log}"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              VirtualizingPanel.IsVirtualizing="True"
                              ScrollViewer.ScrollChanged="LogList_ScrollChanged"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="6,4,6,6">
                        <CheckBox Content="Mute Log" IsChecked="{Binding LogMuted}"
                                  Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <Button Content="Clear" Style="{StaticResource DarkBtn}"
                                Click="ClearLog_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
